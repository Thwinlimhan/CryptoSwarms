# ---------- TimescaleDB ----------
POSTGRES_USER=swarm
POSTGRES_PASSWORD=swarm_change_me
POSTGRES_DB=swarm_db
DB_URL=postgresql://swarm:swarm_change_me@timescaledb:5432/swarm_db

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- Qdrant ----------
QDRANT_URL=http://qdrant:6333

# ---------- Neo4j ----------
# Format required by the Neo4j container: <user>/<password>
NEO4J_AUTH=neo4j/neo4j_change_me
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_change_me

# ---------- Local model serving (SGLang) ----------
SGLANG_URL=http://sglang:30000
SGLANG_MODEL_PATH=Qwen/Qwen2.5-3B-Instruct

# ---------- Swarm API auth ----------
API_AUTH_TOKEN=change_me_api_token

# ---------- Mission Control (optional profile) ----------
MC_USER=admin
MC_PASS=change_me
MC_API_KEY=change_me_api_key
SWARM_API_URL=http://swarm-api:8000
