# App
APP_NAME=CryptoSwarms API
ENVIRONMENT=local
API_HOST=0.0.0.0
API_PORT=8000
SSL_CERTFILE=
SSL_KEYFILE=
# Redis
REDIS_URL=redis://localhost:6379/0

# TimescaleDB
TIMESCALEDB_HOST=localhost
TIMESCALEDB_PORT=5432
TIMESCALEDB_USER=swarm
TIMESCALEDB_PASSWORD=swarm
TIMESCALEDB_DB=swarm_db
DB_PASSWORD=swarm

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=swarm_graph_secret

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Local LLM (SGLang)
SGLANG_HOST=localhost
SGLANG_PORT=30000

# Exchange (paper/testnet first)
EXCHANGE_NAME=hyperliquid_testnet
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_PASSPHRASE=

# Mission Control (upstream)
MC_USER=admin
MC_PASS=admin
MC_API_KEY=change-me
MC_ALLOWED_HOSTS=localhost,127.0.0.1
NEXT_PUBLIC_GATEWAY_HOST=localhost
NEXT_PUBLIC_GATEWAY_PORT=8000
NEXT_PUBLIC_GATEWAY_PROTOCOL=ws

# Optional URLs used by compose services
CAMOUFOX_URL=http://localhost:8080

# LangSmith tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=cryptoswarms


# DeepFlow telemetry
DEEPFLOW_HOST=localhost
DEEPFLOW_PORT=20035
DEEPFLOW_CONTROLLER_IP=127.0.0.1
DEEPFLOW_ENABLED=false
DEEPFLOW_VTAP_GROUP_ID=g-cryptoswarms

