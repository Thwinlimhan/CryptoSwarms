# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=CryptoSwarms API
ENVIRONMENT=local
API_HOST=0.0.0.0
API_PORT=8000

# Security — change BOTH values before any non-local deployment
API_KEY=change-me-to-a-random-secure-string
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# TLS (optional — leave blank for plain HTTP)
SSL_CERTFILE=
SSL_KEYFILE=

# ── Core Infra ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

TIMESCALEDB_HOST=localhost
TIMESCALEDB_PORT=5432
TIMESCALEDB_USER=swarm
TIMESCALEDB_PASSWORD=swarm
TIMESCALEDB_DB=swarm_db
DB_PASSWORD=swarm

# ── Exchange (paper / testnet first) ──────────────────────────────────────────
EXCHANGE_NAME=hyperliquid_testnet
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_PASSPHRASE=

# ── Hyperliquid / HyPaper ─────────────────────────────────────────────────────
HYPERLIQUID_API_URL=http://localhost:3001
HYPERLIQUID_WS_URL=ws://localhost:3001/ws
HYPERLIQUID_WALLET=0x000000000000000000000000000000000000paper
HYPERLIQUID_MODE=paper

# ── Mission Control upstream dashboard ─────────────────────────────────────────
MC_USER=admin
MC_PASS=admin
MC_API_KEY=change-me
MC_ALLOWED_HOSTS=localhost,127.0.0.1
NEXT_PUBLIC_GATEWAY_HOST=localhost
NEXT_PUBLIC_GATEWAY_PORT=8000
NEXT_PUBLIC_GATEWAY_PROTOCOL=ws

# ── External services ──────────────────────────────────────────────────────────
CAMOUFOX_URL=http://localhost:8080

# ── LangSmith tracing (optional) ──────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=cryptoswarms

# ── DeepFlow observability (optional — keep DEEPFLOW_ENABLED=false for local) ──
DEEPFLOW_HOST=localhost
DEEPFLOW_PORT=20035
DEEPFLOW_CONTROLLER_IP=127.0.0.1
DEEPFLOW_ENABLED=false
DEEPFLOW_VTAP_GROUP_ID=g-cryptoswarms

# ── Disabled / optional services (uncomment to enable) ────────────────────────
# Neo4j — used by graphiti-core memory graph
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=swarm_graph_secret
#
# Qdrant — vector store for semantic search
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
#
# SGLang — local LLM inference server
# SGLANG_HOST=localhost
# SGLANG_PORT=30000
